    // SMS Service Common
    def smsCommonService(String msg, def phoneno, def organization, def template_id) {
        def smsprovider = SMSServiceProvider.findByIs_activeAndOrganization(true, organization)
        def responce
        if(smsprovider?.sms_provider_name == 'TEXTLOCAL')
            responce = sendSmslcl(msg, phoneno)
        else if(smsprovider?.sms_provider_name == 'SMS123')
            responce = sendSms123(msg, phoneno, organization, smsprovider?.sender, smsprovider?.username, smsprovider?.password)
        else if(smsprovider?.sms_provider_name == 'VT')
            responce = sendSmsVT(msg, phoneno, organization, smsprovider?.sender, smsprovider?.username, smsprovider?.password,template_id,smsprovider?.api_base_url,smsprovider?.header)
        else if(smsprovider?.sms_provider_name == 'GCS')
            responce = sendSmsGCS(msg, phoneno, organization, smsprovider?.sender, smsprovider?.username, smsprovider?.password, smsprovider?.header, template_id)
        else if(smsprovider?.sms_provider_name == 'JustMessaging')
            responce = sendSmsJustMessaging(msg, phoneno,  smsprovider?.sender, smsprovider?.username, smsprovider?.password, smsprovider?.api_base_url)
        else if(smsprovider?.sms_provider_name == 'VISIONHLT')
            responce = sendSmsVISIONHLT(msg, phoneno,  smsprovider?.sender, smsprovider?.username, smsprovider?.password, smsprovider?.api_base_url)
        else if(smsprovider?.sms_provider_name == 'buzzify')
            responce = sendSmsbuzzify(msg, phoneno,  smsprovider?.sender, smsprovider?.username, smsprovider?.password, smsprovider?.api_base_url)
        else if(smsprovider?.sms_provider_name == 'AMAZONWITHTEMPLATE') {
            if(phoneno.size() == 12 && !phoneno?.contains("+"))
                phoneno = "+"+phoneno
            else if(!phoneno?.contains("+91"))
                phoneno = "+91"+phoneno
            if(template_id)
                responce = SendMailService.awsTemplateBasedSMS(msg, phoneno, smsprovider?.sender, smsprovider?.header, template_id)
            else
                return 0
        }
        else if(smsprovider?.sms_provider_name == 'AMAZON') {
            def phonenos = []
            if(!phoneno?.contains("+91"))
                phonenos.add("+91"+phoneno)
            else
                phonenos.add(phoneno)
            responce = SendMailService.sendSMS_withAWS(msg, phonenos)
        }
        println("responce SMS : "+responce)
        return responce
    }
    def sendSmsVISIONHLT(msg, phoneno, sender, username,password,api_base_url) {

        try {
            if(phoneno.size() == 12)
                phoneno = phoneno
            else if(!phoneno?.contains("91"))
                phoneno = "91"+phoneno
            if (password && sender && phoneno) {
                URI uri = new URIBuilder(api_base_url)
                        .addParameter("APIKey", password)
                        .addParameter("senderid", sender)
                        .addParameter("channel", "Trans")
                        .addParameter("DCS", "0")
                        .addParameter("flashsms", "0")
                        .addParameter("number", phoneno)
                        .addParameter("text", msg)
                        .build();
                CloseableHttpClient client = HttpClients.createDefault();
                HttpGet request = new HttpGet(uri);

                CloseableHttpResponse response = client.execute(request)
                String responseBody = EntityUtils.toString(response.getEntity());
                JSONObject temp = new JSONObject(responseBody)
                if (temp?.ErrorCode == "000" || temp?.ErrorCode == 000)
                    return 1
                else
                    return  0
            }
            else
                return 0
        } catch (Exception e) {
            return 0
            e.printStackTrace();
        }
    }
    //sms123 sms send service
    def sendSms123(String msg, def phoneno, def organization, def sender, def username, def password) {
        println("sendSms123")
        try {
            String usernamestr = "?username="+username
            String passwordstr = "&password="+password
            String senderstr = "&sender="+sender

//            if(organization?.organization_code == 'VIT')
//            {
//                username = "?username="+'vitpnq'
//                password = "&password="+"vitpnq12"
//                sender = "&sender="+"VISWAK"
//            }else if(organization?.organization_code == 'VIIT'){
//                username = "?username="+'viitkondhwa'
//                password = "&password="+"viitkondhwa123"
//                sender = "&sender="+"INFSMS"
//            }

            if(usernamestr&&passwordstr&&senderstr) {
                def mobno = "&mob=" + phoneno
                msg = msg.replaceAll(" ", "%20")
                String message = "&msg=" + msg
                String data = usernamestr + passwordstr + mobno + message + senderstr
                HttpURLConnection conn = (HttpURLConnection) new URL("http://www.sms123.in/QuickSend.aspx" + data).openConnection();
                conn.setDoOutput(true);
                conn.setRequestMethod("POST");
                conn.setRequestProperty("Content-Length", Integer.toString(data.length()));
                conn.getOutputStream().write(data.getBytes("UTF-8"));
                final BufferedReader rd = new BufferedReader(new InputStreamReader(conn.getInputStream()));
                final StringBuffer stringBuffer = new StringBuffer();
                String line;
                while ((line = rd.readLine()) != null) {
                    stringBuffer.append(line);
                }
                rd.close();
                if (stringBuffer.toString().contains('Error code- 000')) {
                    return 1
                } else
                    return 0
            }else{
                return 0
            }
        } catch (Exception e) {
            System.out.println("Error SMS "+e);
            return 0
        }
    }
    def sendSmsVT(String msg, def phoneno, def organization, def sender, def username, def password,template_id,api_base_url,entity) {
        println("sendSms123")
        try {
            phoneno = phoneno.trim()
            if (username && password && sender) {
                ArrayList arrayList=new ArrayList()
                arrayList.add(phoneno)
                JSONObject json = new JSONObject();
                json.put("username", username);
                json.put("apikey", password);
                json.put("msgtype", "PM");
                json.put("msgtext", msg);
                json.put("signature", sender);
                json.put("templateid", template_id);
                json.put("entity", entity);
                json.put("dest", arrayList);
                println "json.toString()=="+json.toString()
                println "api_base_url=="+api_base_url
                CloseableHttpClient httpClient = HttpClientBuilder.create().build();
                HttpPost request = new HttpPost(api_base_url);
                StringEntity params = new StringEntity(json.toString());
                request.addHeader("content-type", "application/json");
                request.setEntity(params);
                HttpResponse response = httpClient.execute(request);
                int statusCode = response.getStatusLine().getStatusCode();
                println "statusCode=="+statusCode
                BufferedReader rd = new BufferedReader(new InputStreamReader(response.getEntity().getContent()));
                String line;
                String line1;
                int i = 0
                while ((line = rd.readLine()) != null) {
                    if (i == 0) {
                        line1 = line
                    } else {
                        line1 += line
                    }
                    i++
                }
                println "line1=="+line1

//                String line;
//                while ((line = rd.readLine()) != null) {
//                    stringBuffer.append(line);
//                }
//                rd.close();
//                def str = stringBuffer.toString()
//                if (str.contains('SUBMITTED')) {
//                    return 1
//                } else
//                    return 0
            } else {
                return 0
            }

        } catch (Exception e) {
            System.out.println("Error SMS " + e);
            return 0
        }
    }
    def sendSmsbuzzify(String msg, def phoneno, def sender, def username, def password,api_base_url) {
        try {
            String usernamestr = "?apikey="+username
            String senderstr = "&senderid="+sender
            if(usernamestr&&senderstr) {
                def mobno = "&number=" + phoneno
                msg = msg.replaceAll(" ", "%20")
                String message = "&message=" + msg
                String data = usernamestr  + mobno + message + senderstr+'&format=JSON'
                HttpURLConnection conn = (HttpURLConnection) new URL(api_base_url + data).openConnection();
                conn.setDoOutput(true);
                conn.setRequestMethod("GET");
                conn.setRequestProperty("Content-Length", Integer.toString(data.length()));
//                conn.getOutputStream().write(data.getBytes("UTF-8"));
                final BufferedReader rd = new BufferedReader(new InputStreamReader(conn.getInputStream()));
                final StringBuffer stringBuffer = new StringBuffer();
                String line;
                while ((line = rd.readLine()) != null) {
                    stringBuffer.append(line);
                }
                rd.close();
                if (stringBuffer.toString().contains('OK')) {
                    return 1
                } else
                    return 0
            }else{
                return 0
            }
        } catch (Exception e) {
            System.out.println("Error SMS "+e);
            return 0
        }
    }

