    def convertToJson(variableval)
    {
        JSONObject json = new JSONObject(variableval);
        return json
    }

    def getMedian(def array){
        array?.sort{it}
        int length = array?.size();
        if (length % 2 == 0) {
            // Even number of elements: take the average of the two middle array
            return (array[(int) Math.round(length / 2 - 1)] + array[(int) Math.round(length / 2)]) / 2.0;
        } else {
            // Odd number of elements: take the middle number
            def l = length.intdiv(2)
            return array[l];
        }
    }



    def getOutwardNo(type,org,ay,uid,ip,is_save)
    {
        println(" ay "+ay)
        println(" ay "+org)
        SerialFieldType sft
        SerialFieldMaster sfm
        SerialFieldTracking serial_track
        if(type=='Leaving Certificate')
            type='Transfer Certificate'
             sft = SerialFieldType.findByNameAndOrganization(type,org)
        println("sft "+sft)
             sfm = SerialFieldMaster.findByAcademicyearAndOrganizationAndSerialfieldtype(ay,org,sft)
        println("sfm"+sfm)
             serial_track = SerialFieldTracking.findByOrganizationAndAcademicyearAndSerialfieldmaster(org,ay,sfm)

        if(is_save==true || serial_track == null){
            serial_track= saveSerialNumberTrack(serial_track,sft,sfm,org,ay,uid,ip)
        }
        println("serial_track "+serial_track)
        int grno=serial_track.track
        int gr=grno, cnt=0,dig=sfm.number_of_digits
        while(gr > 0) {
            gr = gr / 10;
            cnt = cnt + 1;
        }
        // println cnt
        String zeroes=""
        for(int i=cnt;i<dig;i++){
            zeroes+="0"
        }
        def numbers=''
        numbers=(sfm.prefixvalue?sfm.prefixvalue:'')+zeroes+grno
        println("sfm.prefixvalue+zeroes+grno =========="+numbers)
        return(numbers)
    }

    def saveSerialNumberTrack(serial_track,sft,sfm,org,ay,uid,ip){
        println("saveSerialNumberTrack----------------------")
        if(serial_track==null){
            serial_track = new SerialFieldTracking()
            serial_track.creation_username = uid
            serial_track.creation_date = new java.util.Date()
            serial_track.creation_ip_address = ip
            serial_track.organization = org
            serial_track.serialfieldtype = sft
            serial_track.serialfieldmaster = sfm
            serial_track.academicyear = ay
            serial_track.track = 1
            serial_track.updation_username = uid
            serial_track.updation_date = new java.util.Date()
            serial_track.updation_ip_address = ip
        }
        else {
            serial_track.updation_username = uid
            serial_track.updation_date = new java.util.Date()
            serial_track.updation_ip_address = ip
            serial_track.track += 1
        }
        serial_track.save(failOnError: true, flush: true)
        return  serial_track
    }


    def checkismigration_allowed_wo_tc(org,learnerData){
        def ismigration_allowed_wo_tc
        def istc_neededformigration = ERPRoleTypeSettings.findByNameIlikeAndOrganization('TC/LC is required for Migration Certificate', org)?.value
        println "istc_neededformigration =======> ${istc_neededformigration} and type : ${istc_neededformigration?.class?.name}"
        if(istc_neededformigration =='true') {
            ERPDocumentMaster document_tc = ERPDocumentMaster.findByDocument_nameAndOrganization('Transfer Certificate',org)
            def tc = ERPDocumentRequestEditMaster.createCriteria().list() {
                like("organization", org)
                and {
                    like("learner", learnerData)
                    like("erpdocumentmaster", document_tc)
                }
            }
            ismigration_allowed_wo_tc = tc ? true : false
            return ismigration_allowed_wo_tc
        }
    }

    def get_tc_num(org,learnerData){


        ERPDocumentMaster document_tc = ERPDocumentMaster.findByDocument_nameAndOrganization('Transfer Certificate',org)
        def tc = ERPDocumentRequestEditMaster.createCriteria().list() {
            like("organization", org)
            and {
                like("learner", learnerData)
                like("erpdocumentmaster", document_tc)
            }
        }

        def tcno
        if(tc && tc[0]?.lcno)
            tcno=tc[0]?.lcno
        else if(tc && tc[0]?.document_outword_number)
            tcno=tc[0]?.document_outword_number

        return tcno
    }

}

