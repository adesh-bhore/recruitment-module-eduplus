                    conn.setRequestMethod("POST");
                    conn.setRequestProperty("Content-Length", Integer.toString(data.length()));
                    conn.getOutputStream().write(data.getBytes("UTF-8"));
                    final BufferedReader rd = new BufferedReader(new InputStreamReader(conn.getInputStream()));
                    final StringBuffer stringBuffer = new StringBuffer();
                    String line;
                    while ((line = rd.readLine()) != null) {
                        stringBuffer.append(line);
                    }
                    rd.close();
                    def str = stringBuffer.toString()
                    JSONObject temp = new JSONObject(str)
                    if (temp.getString("ErrorCode")=="000") {
                        return 1
                    } else
                        return 0
                } else {
                    return 0
                }
            }else{
                return 0
            }
        } catch (Exception e) {
            System.out.println("Error SMS "+e);
            return 0
        }
    }

    def no_of_slot_per_lecture(def erpcourseofferingbatch, def organization){
        def roletypesettingpracticalhr
        if(erpcourseofferingbatch?.duration > 0)
            roletypesettingpracticalhr = erpcourseofferingbatch?.duration
        else {
            if (erpcourseofferingbatch?.loadtype?.type?.type == "Lab")
                roletypesettingpracticalhr = ERPRoleTypeSettings.findByNameIlikeAndOrganization('No. of Practical Hours Per Turn', organization)?.value
            else if (erpcourseofferingbatch.loadtype.type.type == "Tutorial")
                roletypesettingpracticalhr = ERPRoleTypeSettings.findByNameIlikeAndOrganization('No. of Tutorial Hours Per Turn', organization)?.value
            if (roletypesettingpracticalhr)
                roletypesettingpracticalhr = Integer.parseInt(roletypesettingpracticalhr)
            else
                roletypesettingpracticalhr = 1
        }

        return roletypesettingpracticalhr
    }


    def getStudentAttendanceBatches(def erpcourseofferingbatch){
        def erpcourseofferingbatchlist = new ArrayList()

        for (ERPCourseOfferingBatch e : erpcourseofferingbatch) {
            //If course rule is 'EL' or 'EL-Div' then division offering not required
            if(e?.erpcourseoffering?.courserule?.name == 'EL' && e?.erpcourseoffering?.erpcoursecategory?.name != 'EL-Div'){
                if(e?.divisionoffering == null)
                    erpcourseofferingbatchlist.add(e)
            }
            else {
                if(e?.divisionoffering != null)
                    erpcourseofferingbatchlist.add(e)
            }
        }

        return erpcourseofferingbatchlist
    }


    //Mark Usage
    def markUsageLogs(def pagename, def description, def curr_controller, def curr_action, def ipaddress, def loginid, def bypassloginid, def usagetype){

        if(curr_action=='dynamicrolelinks')
            return

        Login login = Login.findById(loginid)
        Login byPassLogin = Login.findById(bypassloginid)

        def loginuser = login
        def bypassloginuser
        if(byPassLogin) {
            loginuser = byPassLogin
            bypassloginuser = login
        }

        def inst = Instructor.findByUid(loginuser?.username)
        if(inst) {
            UsageLogs usagelogs = new UsageLogs()
            usagelogs?.pagename = pagename
            usagelogs?.description = description
            usagelogs?.ipaddress = ipaddress
            usagelogs?.person = inst?.person
            if(bypassloginuser){
                def useraccessedperson = Instructor.findByUid(bypassloginuser?.username)
                if(useraccessedperson)
                    usagelogs?.useraccessed = useraccessedperson?.person
            }

            usagelogs?.controller = curr_controller
            usagelogs?.action = curr_action
            usagelogs?.usagetype = usagetype
            usagelogs?.devicename = "ADMIN WEB"
            usagelogs?.accesstime = new java.util.Date()
            usagelogs?.organization = inst?.organization
            usagelogs.save(flush: true, failOnError: true)
        }
    }

    //faculty profile count
    def getFacultyProfileCount(request,instructor,ay,hm,params)
    {
        EmployeeAttendanceService attendanceService = new EmployeeAttendanceService()
        def rulecount =[]
        def facultycount = []
        if(instructor) {
            def subparameterappraisal = ERPSelfAppraisalSubParameter.createCriteria().list() {
                'in'('organization', instructor.organization)
                and {
                    'in'('academicyear', ay)
                    isNotNull('erpselfappraisalsubparameterrule')
                }
            }
            subparameterappraisal.sort{it?.erpselfappraisalsubparameterrule?.sequence}
            for (subparameter in subparameterappraisal) {
                HashMap hm1 = new HashMap()
                // def subparameter1 = ERPSelfAppraisalSubParameter.findByOrganizationAndAcademicyearAndErpselfappraisalsubparameterrule(instructor.organization,ay,subparameter?.erpselfappraisalsubparameterrule)
                def positioninstructor = ERPSelfAppraisalPositionInstructor.findByOrganizationAndAcademicyearAndInstructor(instructor.organization,ay,instructor)
                def target
                int targetcountdays=0
                if(subparameter.is_target_applicable_to_individual){
                    target = ERPSelfAppraisalSubParaPosition.findByErpselfappraisalsubparameterAndInstructor(subparameter,instructor)
                }
                else {
                    target= ERPSelfAppraisalSubParaPosition.findByErpselfappraisalsubparameterAndErpselfappraisalposition(subparameter,positioninstructor?.erpselfappraisalposition)
                    if(target) {
                        if (target.target == 0 && target?.target_displayname) {
                            def string = target?.target_displayname
                            string = target?.target_displayname.split(' ')[0]
                            targetcountdays = Integer.parseInt(string)
                        }
                    }
                }
                if(subparameter?.erpselfappraisalsubparameterrule?.name != null) {
                    hm1.put("discription", subparameter?.subparameter_name)
                    hm1.put("rule", subparameter?.erpselfappraisalsubparameterrule?.name)
                    //Citations
                    if (subparameter?.erpselfappraisalsubparameterrule?.name == "Citation") {
                        facultycount = Instructor.createCriteria().list() {
                            'in'('organization', instructor.organization)
                            and {
                                'in'('id', instructor?.id)
                            }
                        }
                        String citations = ""
                        citations = facultycount?.current_year_citations.toString().replace("[", "").replace("]", "");
                        hm1.put("count", citations)
                        hm1.put("employee", facultycount)
                        hm1.put("target", target?.target)
                        if (facultycount?.current_year_citations[0] >= target?.target) {
                            hm1.put("achived", true)
                        }
                    }
                    //Admin Responsiblities
                    if (subparameter?.erpselfappraisalsubparameterrule?.name == "Admin Responsiblities") {
                        facultycount = Responsibility.createCriteria().list() {
                            'in'('instructor', instructor)
                            and {
                                'in'('organization', instructor.organization)
                                'in'('appraisalacademicyear', ay)
                            }
                        }
                        hm1.put("count", facultycount.size())
                        hm1.put("employee", facultycount)
                        hm1.put("target", target?.target)
                        if (facultycount.size() >= target?.target) {
                            hm1.put("achived", true)
                        }
                    }
                    //PATENTS FILED
                    if (subparameter?.erpselfappraisalsubparameterrule?.name == "PATENTS FILED") {
                        def filled = PatentStatus.findByStatusAndOrganization("Filed", instructor.organization)
                        def count
                        def researchinstructorlist = []
                        def mainauthor = []
                        def filledemployeearray = []
                        def inventorlist = []
                        facultycount = Patent.createCriteria().list() {
                            'in'('organization', instructor.organization)
                            and {
                                'in'('patentstatus', filled)
                                'in'('appraisalacademicyear', ay)
                            }
                        }
                        mainauthor = Patent.createCriteria().list() {
                            'in'('instructor', instructor)
                            and {
                                'in'('organization', instructor.organization)
                                'in'('appraisalacademicyear', ay)
                                'in'('patentstatus', filled)
                            }
                        }

                        researchinstructorlist = ResearchInstructor.createCriteria().list() {
                            'in'('instructor', instructor)
                            and {
                                'in'('patent', facultycount)
                            }
                        }

                        inventorlist = PatentInventor.createCriteria().list() {
                            'in'('instructor', instructor)
                            and {
                                'in'('patent', facultycount)
                                if(researchinstructorlist)
                                {
                                    not{
