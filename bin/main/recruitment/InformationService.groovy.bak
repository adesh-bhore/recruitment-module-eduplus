                                }
                            }
                            researchinstructorlist = ResearchInstructor.createCriteria().list() {
                                'in'('instructor', instructor)
                                and {
                                    'in'('publication', facultycount)
                                }
                            }
                            count = mainauthor.size() + researchinstructorlist.size()
                            if(mainauthor.size() >0)
                            {
                                for (emp in mainauthor)
                                {
                                    confetencearray.add(emp)
                                }
                            }

                            if(researchinstructorlist.size() > 0)
                            {
                                for (emp in researchinstructorlist?.publication)
                                {
                                    confetencearray.add(emp)
                                }
                            }
                        }
                        hm1.put("count", count)
                        hm1.put("employee", confetencearray)
                        hm1.put("target", target?.target)
                        if (count >= target?.target) {
                            hm1.put("achived", true)
                        }
                    }
                    //FDP/STTP/GUEST LECTURE/KEYNOTE /SESSION CHAIR  RESOURCE PERSON
                    if (subparameter?.erpselfappraisalsubparameterrule?.name == "FDP/STTP/GUEST LECTURE/KEYNOTE /SESSION CHAIR  RESOURCE PERSON") {
                        def trainingrole = TrainingRole.findAllByNameInListAndOrganization(["Resource Person"], instructor?.organization)
                        def facultycounttraining
                        if(trainingrole) {
                            facultycounttraining = Training.createCriteria().list() {
                                'in'('instructor', instructor)
                                and {
                                    'in'('organization', instructor.organization)
                                    'in'('trainingrole', trainingrole)
                                    'in'('appraisalacademicyear', ay)
                                }
                            }
                        }
                        if(target?.target_displayname && target?.target == 0 ){
                            int count =0
                            for(tran in facultycounttraining){
                                def trainingdaysDays = attendanceService.getDaysDiff(tran.fromdate, tran.todate)
                                int days = Integer.parseInt(trainingdaysDays.toString())
                                count = count+days
                            }
                            hm1.put("count", count)
                            hm1.put("employee", facultycount)
                            hm1.put("target", target?.target_displayname)
                            if (count >= targetcountdays) {
                                hm1.put("achived", true)
                            }
                        }
                        else{
                            hm1.put("count", facultycount?.size())
                            hm1.put("employee", facultycount)
                            hm1.put("target", target?.target)
                            if (facultycount.size() >= target?.target) {
                                hm1.put("achived", true)
                            }
                        }
                    }

                    if (subparameter?.erpselfappraisalsubparameterrule?.name == "PHD REGISTRATION BY FACULTY") {
                        def degreetype = DegreeType.findByTypeAndOrganization("PhD", instructor?.organization)
                        def instdegree = InstDegree.findByDegreetypeAndOrganization(degreetype, instructor?.organization)
                        def phdregistration
                        if(instdegree) {
                            phdregistration = InstructorAcademics.createCriteria().list() {
                                'in'('instructor', instructor)
                                and {
                                    'in'('organization', instructor.organization)
                                    'in'('instdegree', instdegree)
                                }
                            }
                        }
                        if(phdregistration){
                            hm1.put("count", "Yes")
                            hm1.put("employee", facultycount)
                            hm1.put("target", "Yes")
                            hm1.put("achived", true)
                        }
                        else{
                            hm1.put("count", 'NO')
                            hm1.put("employee", facultycount)
                            hm1.put("target", 'Yes')
                            hm1.put("achived", false)
                        }
                    }
                    rulecount.add(hm1)
                }
            }
        }
        hm.put("rulecount",rulecount)
        hm.put("status","200")
        hm.put("message","success")
        return
    }

