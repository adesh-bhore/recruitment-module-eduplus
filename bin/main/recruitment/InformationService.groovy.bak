    // Role Assignment History
    def roleAssignmentHistory(def formname, def ip, def role, def assignedbylogin, def assignedtologin){
        println("assignedbylogin "+assignedbylogin)
        println("assignedtologin "+assignedtologin)

        def assignedby = Instructor.findByUid(assignedbylogin?.username)
        println("assignedby =>>"+ assignedby)

        if(!assignedby)
            assignedby = Learner.findByUid(assignedbylogin?.username)

        def assignedto = Instructor.findByUid(assignedtologin?.username)
        if(!assignedto)
            assignedto = Learner.findByUid(assignedtologin?.username)
            RoleHistory rolehistory = new RoleHistory()
            rolehistory.role = role
            rolehistory.formname = formname
            rolehistory.roleassignedby = assignedby?.person
            rolehistory.roleassignedto = assignedto?.person
            rolehistory.organization = assignedby?.organization

            rolehistory.creation_username = assignedby?.username
            rolehistory.creation_date = new Date()
            rolehistory.creation_ip_address = ip
            rolehistory.save(flush: true, failOnError: true)
    }

    def revokeRoleGroup(def revokeformname,def ip,def role,def rolerevokeby ,def rolerevokedfrom)
    {
        println("in revoke role group service")
        def revokeby = Instructor.findByUid(rolerevokeby?.username)
        def revoketo = Instructor.findByUid(rolerevokedfrom?.username)
        if(!revoketo)
            revoketo = Learner.findByUid(rolerevokedfrom?.username)

        RoleHistory rolehistory = RoleHistory.findByRoleAndRoleassignedtoAndOrganization(role,revoketo?.person,revokeby?.organization)
        if(rolehistory) {
            rolehistory.revokeformname = revokeformname
            rolehistory.rolerevokeby = revokeby?.person
            rolehistory.updation_username = revokeby?.username
            rolehistory.updation_date = new Date()
            rolehistory.updation_ip_address = ip
            rolehistory.save(flush: true, failOnError: true)
        }
    }


    // Check Role Group Access
    def getDivisionData(def academicyear, instructor, semester){
        def erpcourseoffering = ERPCourseOffering.createCriteria().list(){
            'in'('organization', instructor?.organization)
            and{
                'in'('academicyear', academicyear)
                'in'('semester', semester)
                eq('isDeleted', false)
            }
        }

        def erpcourseofferingbatch
        if(erpcourseoffering){
            erpcourseofferingbatch = ERPCourseOfferingBatch.createCriteria().list(){
                'in'('erpcourseoffering', erpcourseoffering)
            }
        }

        def erpcourseofferingbatchinstructor
        if(erpcourseofferingbatch){
            erpcourseofferingbatchinstructor = ERPCourseOfferingBatchInstructor.createCriteria().list(){
                'in'('erpcourseofferingbatch', erpcourseofferingbatch)
            }
        }

        HashSet divisionOffering = []
        for(batch in erpcourseofferingbatchinstructor){
            if(batch?.extrainstructor?.id?.contains(instructor?.id) || batch?.instructor?.id == instructor?.id) {
                if (batch?.erpcourseofferingbatch?.divisionoffering)
                    divisionOffering.add(batch?.erpcourseofferingbatch?.divisionoffering)
                else {
                    def learnerlist = ERPCourseOfferingBatchLearner.findAllByErpcourseofferingbatch(batch?.erpcourseofferingbatch)?.learner
                    if(learnerlist) {
                        def divisionlist = LearnerDivision.createCriteria()?.list() {
                            projections {
                                distinct('divisionoffering')
                            }
                            'in'('learner', learnerlist)
                            and{
                                'in'('academicyear', academicyear)
                                'in'('semester', semester)
                                eq('isdeleted', false)
                            }
                        }
                        if(divisionlist)
                            divisionOffering.addAll(divisionlist)
                    }
                }
            }
        }

        def doff = DivisionOffering.findAllByClassteacherAndAcademicyearAndSemesterAndIsregular(instructor, academicyear, semester, true)
        if(doff)
            divisionOffering.addAll(doff)
        def roledivision = getRoleDetails(instructor, 'Class Teacher')
        if(roledivision)
            divisionOffering.addAll(roledivision)

        divisionOffering?.sort{it?.division?.name}

        return divisionOffering
    }

    def getRoleDetails(def instructor, def rolegroupname){
        ApplicationType at = ApplicationType.findByApplication_type("ERP")
        UserType ut = UserType.findByApplication_typeAndTypeAndOrganization(at, "Employee", instructor?.organization)
        def rolegroup = RoleGroup.findByNameIlikeAndOrganizationAndUsertype(rolegroupname , instructor?.organization, ut)
        def rolegroupuser = RoleGroupUser.findAllByEmployeerolegroupAndInstructorAndOrganization(rolegroup, instructor, instructor?.organization)
        if(rolegroupuser) {
            if(rolegroup?.rolelevel?.name?.trim() == 'DepartmentLevel')
                return rolegroupuser?.department
            else if(rolegroup?.rolelevel?.name?.trim() == 'InstituteLevel')
                return rolegroupuser
            else if(rolegroup?.rolelevel?.name?.trim() == 'BranchLevel')
                return rolegroupuser?.program
            else if(rolegroup?.rolelevel?.name?.trim() == 'StreamLevel')
                return rolegroupuser?.stream
            else if(rolegroup?.rolelevel?.name?.trim() == 'BranchYearLevel')
                return rolegroupuser?.programyear
            else if(rolegroup?.rolelevel?.name?.trim() == 'CourseLevel')
                return rolegroupuser?.erpcourse
            else if(rolegroup?.rolelevel?.name?.trim() == 'DivisionLevel')
                return rolegroupuser?.divisionoffering
        }
        else
            return []
    }

    def institutelevelaccess(def instructor, def instrolename){
        def rolegroupuser
        if(instrolename?.size()>0) {
            ApplicationType at = ApplicationType.findByApplication_type("ERP")
            UserType ut = UserType.findByApplication_typeAndTypeAndOrganization(at, "Employee", instructor?.organization)
            def rolegroup = RoleGroup.findAllByNameInListAndOrganizationAndUsertype(instrolename, instructor?.organization, ut)
            if (rolegroup)
                rolegroupuser = RoleGroupUser.findAllByEmployeerolegroupInListAndInstructorAndOrganization(rolegroup, instructor, instructor?.organization)
        }
        if(rolegroupuser)
            return true
        else
            return false
    }

    def departmentlevelaccess(def instructor, deptrolename){
        ApplicationType at = ApplicationType.findByApplication_type("ERP")
        UserType ut = UserType.findByApplication_typeAndTypeAndOrganization(at, "Employee", instructor?.organization)
        def rolegroup = RoleGroup.findAllByNameInListAndOrganizationAndUsertype(deptrolename , instructor?.organization, ut)
        def rolegroupuser
        if(rolegroup)
            rolegroupuser = RoleGroupUser.findAllByEmployeerolegroupInListAndInstructorAndOrganizationAndDepartmentIsNotNull(rolegroup, instructor, instructor?.organization)
        return rolegroupuser?.department
    }

    def branchlevelaccess(def instructor){
        ApplicationType at = ApplicationType.findByApplication_type("ERP")
        UserType ut = UserType.findByApplication_typeAndTypeAndOrganization(at, "Employee", instructor?.organization)
        def rolelevel = RoleLevel.findByNameAndOrganization('BranchLevel', instructor.organization)
        def rolegroup = RoleGroup.findAllByOrganizationAndUsertypeAndRolelevel( instructor?.organization, ut, rolelevel)
        def rolegroupuser
        if(rolegroup)
            rolegroupuser = RoleGroupUser.findAllByEmployeerolegroupInListAndInstructorAndOrganizationAndProgramIsNotNull(rolegroup, instructor, instructor?.organization)

        return rolegroupuser?.program
    }

    def branchyearlevelaccess(def instructor){
        ApplicationType at = ApplicationType.findByApplication_type("ERP")
        UserType ut = UserType.findByApplication_typeAndTypeAndOrganization(at, "Employee", instructor?.organization)
        def rolelevel = RoleLevel.findByNameAndOrganization('BranchYearLevel', instructor.organization)
        def rolegroup = RoleGroup.findAllByOrganizationAndUsertypeAndRolelevel( instructor?.organization, ut, rolelevel)
        def rolegroupuser
        if(rolegroup)
            rolegroupuser = RoleGroupUser.findAllByEmployeerolegroupInListAndInstructorAndOrganizationAndProgramyearIsNotNull(rolegroup, instructor, instructor?.organization)

        return rolegroupuser?.programyear
    }

    def getProgramTypeByRoleGroup(def instructor, def login, def organization, def instrolename, def deptrolename){

        def ismanagement = isManagement(login, instructor, 'Registration')

        HashSet programtype = []
        if(institutelevelaccess(instructor, instrolename) || ismanagement)
            programtype = ProgramType.findAllByOrganization(organization)
        else{
            def department = departmentlevelaccess(instructor, deptrolename)
            if(department) {
                def program = Program.findAllByIsdeletedAndOrganizationAndDepartmentInList(false, instructor.organization, department)
                if(program)
                    programtype.addAll(program?.programtype)
            }

            def programlist = branchlevelaccess(instructor)
            if(programlist)
                programtype.addAll(programlist?.programtype)

            def programyearlist = branchyearlevelaccess(instructor)
            if(programyearlist)
                programtype.addAll(programyearlist?.program?.programtype)
        }

        def programtypelist = []
        for(p in programtype)
            programtypelist.add(p)
        programtypelist?.sort{it?.name}

        return programtypelist
    }

    def getProgramByRoleGroup(def instructor, def login, def organization, def programtypeid, def instrolename, def deptrolename){

        def ismanagement = isManagement(login, instructor, 'Registration')

        HashSet program = []
        if(institutelevelaccess(instructor, instrolename) || ismanagement)
        {def programlist = []
            if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                def programtype = ProgramType.findById(programtypeid)
                programlist = Program.findAllByOrganizationAndProgramtypeAndIsdeleted(organization, programtype, false)
            }else
                programlist = Program.findAllByOrganizationAndIsdeleted(organization, false)
            if(programlist)
                program.addAll(programlist)
        }else{
            def department = departmentlevelaccess(instructor, deptrolename)
            if(department) {
                def programlist = []
                if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                    def programtype = ProgramType.findById(programtypeid)
                    programlist = Program.findAllByIsdeletedAndOrganizationAndProgramtypeAndDepartmentInList(false, organization, programtype, department)
                }else
                    programlist = Program.findAllByIsdeletedAndOrganizationAndDepartmentInList(false, organization, department)
                if(programlist)
                    program.addAll(programlist)
            }
            def programlist = branchlevelaccess(instructor)
            if(programlist) {
                if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                    def programtype = ProgramType.findById(programtypeid)
                     for(prog in programlist)
                     {
                         if(prog?.programtype?.id == programtype?.id)
                             program.add(prog)
                     }
                }else
                    program.addAll(programlist)
            }

            def programyearlist = branchyearlevelaccess(instructor)
            if(programyearlist) {
                if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                    def programtype = ProgramType.findById(programtypeid)
                    for(progyear in programyearlist)
                    {
                        if(progyear?.program?.programtype?.id == programtype?.id)
                            program.add(progyear?.program)
                    }
                }else
                     program.addAll(programyearlist?.program)
            }

        }

        def programlist = []
        for(p in program)
            programlist.add(p)
        programlist?.sort{it?.name}

        return programlist
    }

    def getYearByRoleGroup(def instructor, def login, def organization, def programtypeid, def programId, def instrolename, def deptrolename){

        def ismanagement = isManagement(login, instructor, 'Registration')

        HashSet year = []
        if(institutelevelaccess(instructor, instrolename) || ismanagement){
            if(programId != null && programId != "" && programId != 'All' && programId != 'null' && programId != '0') {
                def program = Program.findById(programId)
                if(program) {
                    year = ProgramYear.createCriteria().list() {
                        projections {
                            distinct('year')
                        }
                        and {
                            'in'('program', program)
                        }
                    }
                }
            }else if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                def ProgramType = ProgramType.findById(programtypeid)
                if(ProgramType) {
                    year = ProgramTypeYear.createCriteria().list() {
                        projections {
                            distinct('year')
                        }
                        and {
                            'in'('programtype', ProgramType)
                        }
                    }
                }
            }else {
                year = Year.findAllByOrganization(organization)
            }
        }else{
            def department = departmentlevelaccess(instructor, deptrolename)
            if(department) {
                def programlist = []
                if(programId != null && programId != "" && programId != 'All' && programId != 'null' && programId != '0') {
                    programlist = Program.findByIdAndDepartmentInList(programId, department)
                }else if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                    def ProgramType = ProgramType.findById(programtypeid)
                    if(ProgramType)
                        programlist = Program.findAllByIsdeletedAndOrganizationAndProgramtypeAndDepartmentInList(false, organization, ProgramType, department)
                }else {
                    programlist = Program.findAllByIsdeletedAndOrganizationAndDepartmentInList(false, organization, department)
                }
                if(programlist) {
                    year = ProgramYear.createCriteria().list() {
                        projections {
                            distinct('year')
                        }
                        and {
                            'in'('program', programlist)
                        }
                    }
                }
            }

            def programlist = branchlevelaccess(instructor)
            if(programlist) {
                HashSet program = []
                if(programId != null && programId != "" && programId != 'All' && programId != 'null' && programId != '0') {
                    def progname = Program.findById(programId)
                    for(prog in programlist)
                    {
                        if(prog?.id == progname?.id)
                            program.add(prog)
                    }
                }else if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                    def programtype = ProgramType.findById(programtypeid)
                    for(prog in programlist)
                    {
                        if(prog?.programtype?.id == programtype?.id)
                            program.add(prog)
                    }
                }else
                    program.addAll(programlist)

                if(program) {
                    year = ProgramYear.createCriteria().list() {
                        projections {
                            distinct('year')
                        }
                        and {
                            'in'('program', program)
                        }
                    }
                }
            }

            def programyearlist = branchyearlevelaccess(instructor)
            if(programyearlist) {
                if(programId != null && programId != "" && programId != 'All' && programId != 'null' && programId != '0') {
                    def progname = Program.findById(programId)
                    for(progyear in programyearlist)
                    {
                        if(progyear?.program?.id == progname?.id)
                            year.add(progyear?.year)
                    }
                }else if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                    def programtype = ProgramType.findById(programtypeid)
                    for(progyear in programyearlist)
                    {
                        if(progyear?.program?.programtype?.id == programtype?.id)
                            year.add(progyear?.year)
                    }
                }else
                    year.addAll(programyearlist?.year)
            }
        }

        def yearlist = []
        if(year)
            yearlist?.addAll(year)
        yearlist?.sort{it?.sort_oder}
        return yearlist
    }

    def getDivisionByRoleGroup(def instructor, def login, def organization, def programtypeid, def programId, def instrolename, def deptrolename, def academicyear, def semester){

        def ismanagement = isManagement(login, instructor, 'Registration')

        HashSet division = []
        if(institutelevelaccess(instructor, instrolename) || ismanagement){
            def program = []
            def year = []
            if(programId != null && programId != "" && programId != 'All' && programId != 'null' && programId != '0') {
                program = Program.findById(programId)
                if(program) {
                    year = ProgramYear.createCriteria().list() {
                        projections {
                            distinct('year')
                        }
                        and {
                            'in'('program', program)
                        }
                    }
                }
            }else if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                def ProgramType = ProgramType.findById(programtypeid)
                if(ProgramType) {
                    program = Program.findAllByOrganizationAndProgramtypeAndIsdeleted(organization, ProgramType, false)
                    year = ProgramTypeYear.createCriteria().list() {
                        projections {
                            distinct('year')
                        }
                        and {
                            'in'('programtype', ProgramType)
                        }
                    }
                }
            }else {
                program = Program.findAllByOrganizationAndIsdeleted(organization, false)
                year = Year.findAllByOrganization(organization)
            }

            if(program && year) {
                def divisionlist = DivisionOffering.createCriteria().list() {
                    'in'('organization', organization)
                    and {
                        'in'('academicyear', academicyear)
                        'in'('semester', semester)
                        'in'('program', program)
                        'in'('year', year)
                        eq('isregular', true)
                    }
                }

                if(divisionlist)
                    division.addAll(divisionlist)
            }
        }else{
            def department = departmentlevelaccess(instructor, deptrolename)
            if(department) {
                def programlist = []
                def year = []
                if(programId != null && programId != "" && programId != 'All' && programId != 'null' && programId != '0') {
                    programlist = Program.findByIdAndDepartmentInList(programId, department)
                }else if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                    def ProgramType = ProgramType.findById(programtypeid)
                    if(ProgramType)
                        programlist = Program.findAllByIsdeletedAndOrganizationAndProgramtypeAndDepartmentInList(false, organization, ProgramType, department)
                }else {
                    programlist = Program.findAllByIsdeletedAndOrganizationAndDepartmentInList(false, organization, department)
                }
                if(programlist) {
                    year = ProgramYear.createCriteria().list() {
                        projections {
                            distinct('year')
                        }
                        and {
                            'in'('program', programlist)
                        }
                    }

                    if(year) {
                        def divisionlist = DivisionOffering.createCriteria().list() {
                            'in'('organization', organization)
                            and {
                                'in'('academicyear', academicyear)
                                'in'('semester', semester)
                                'in'('program', programlist)
                                'in'('year', year)
                                eq('isregular', true)
                            }
                        }

                        if(divisionlist)
                            division.addAll(divisionlist)
                    }
                }
            }

            def programlist = branchlevelaccess(instructor)
            if(programlist) {
                HashSet program = []
                HashSet yearlist = []
                if(programId != null && programId != "" && programId != 'All' && programId != 'null' && programId != '0') {
                    def progname = Program.findById(programId)
                    for(prog in programlist)
                    {
                        if(prog?.id == progname?.id)
                            program.add(prog)
                    }
                }else if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                    def programtype = ProgramType.findById(programtypeid)
                    for(prog in programlist)
                    {
                        if(prog?.programtype?.id == programtype?.id)
                            program.add(prog)
                    }
                }else
                    program.addAll(programlist)

                if(program) {
                    yearlist = ProgramYear.createCriteria().list() {
                        projections {
                            distinct('year')
                        }
                        and {
                            'in'('program', program)
                        }
                    }

                    if(yearlist) {
                        def divisionlist = DivisionOffering.createCriteria().list() {
                            'in'('organization', organization)
                            and {
                                'in'('academicyear', academicyear)
                                'in'('semester', semester)
                                'in'('program', program)
                                'in'('year', yearlist)
                                eq('isregular', true)
                            }
                        }

                        if(divisionlist)
                            division.addAll(divisionlist)
                    }
                }
            }

            def programyearlist = branchyearlevelaccess(instructor)

            if(programyearlist) {
                def program = []
                def yearlist = []
                if(programId != null && programId != "" && programId != 'All' && programId != 'null' && programId != '0') {
                    program = Program.findById(programId)
                    for(progyear in programyearlist)
                    {
                        if(progyear?.program?.id == progname?.id)
                            yearlist.add(progyear?.year)
                    }
                }else if(programtypeid != null && programtypeid != "" && programtypeid != 'All' && programtypeid != 'null' && programtypeid != '0') {
                    def programtype = ProgramType.findById(programtypeid)
                    for(progyear in programyearlist)
                    {
                        if(progyear?.program?.programtype?.id == programtype?.id) {
                            yearlist.add(progyear?.year)
                            program.add(progyear?.program)
                        }
                    }
                }else {
                    yearlist.addAll(programyearlist?.year)
                    program.addAll(programyearlist?.program)
                }
                if(yearlist &&  program) {
                    def divisionlist = DivisionOffering.createCriteria().list() {
                        'in'('organization', organization)
                        and {
                            'in'('academicyear', academicyear)
                            'in'('semester', semester)
                            'in'('program', program)
                            'in'('year', yearlist)
                            eq('isregular', true)
                        }
                    }

                    if(divisionlist)
                        division.addAll(divisionlist)
                }
            }

            def list = getDivisionData(academicyear, instructor, semester)
            if(list)
                division.addAll(list)
        }

        division?.sort{it?.division?.name}
        return division
    }

    def getDepartmentByRoleGroup(def login, def instructor, def organization, def instrolename, def deptrolename){

        def ismanagement = isManagement(login, instructor, 'Feedback')
        HashSet department = []
        if(institutelevelaccess(instructor, instrolename) || ismanagement) {
            department = Department.findAllByOrganization(organization)
        }else{
            department = departmentlevelaccess(instructor, deptrolename)
        }
        department?.sort{it?.name}

        return department
    }

    def getAcademicsDepartmentByRoleGroup(def login, def instructor, def organization, def instrolename, def deptrolename){

        def ismanagement = isManagement(login, instructor, 'Feedback')
        DepartmentType dt = DepartmentType.findByName('Academics')
        def department = []
        if(institutelevelaccess(instructor, instrolename) || ismanagement) {
            department = Department.findAllByOrganizationAndDepartmenttype(organization,dt)
        }else{
            def departmentlist = departmentlevelaccess(instructor, deptrolename)
            for(dept in departmentlist){
                if(dept?.departmenttype?.id == dt?.id && !department?.id?.contains(dept?.id))
                    department.add(dept)
            }
        }

        department?.sort{it?.name}
        return department
    }

