    def password_generation()
    {
        java.util.Random random=new java.util.Random()
        String otp=""
        int min=0,max=0,n
        for(int i=1;i<=8;i++)
        {
            if(i==1)
                min=1
            else
                min=0
            max=9
            n=random.nextInt(max)+min
            otp=otp+n
        }

        return otp
    }

    def password_generation_gsuit() {
        java.util.Random random=new java.util.Random()
        String otp=""
        int min=0,max=0,n
        for(int i=1;i<=5;i++) {
            if(i==1)
                min=1
            else
                min=0
            max=9
            n=random.nextInt(max)+min
            char c=(char)(n + 64)
            otp=otp+c
        }
        otp = otp + "@"
        for(int i=1;i<=4;i++) {
            if(i==1)
                min=1
            else
                min=0
            max=9
            n=random.nextInt(max)+min
            otp=otp+n
        }

        return otp
    }

