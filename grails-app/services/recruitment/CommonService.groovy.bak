    }

    def daysBetween(Date d1, Date d2) {
        return (int)( (d2.getTime() - d1.getTime()) / (1000 * 60 * 60 * 24));
    }

    def saveDTEInformation(String application_id,String name_of_candidate,String merit_no,String mht_cet_score, ApplicationAcademicYear aay,Gender gender,ERPAdmissionRound erpAdmissionRound,ERPStudentAdmissionMainCategory erpStudentAdmissionMainCategory,ERPShift erpShift,ERPSeatType erpSeatType,Program program,Year year,Organization org,DTEAllotmentList dal,String jee_marks,String diploma_marks, ERPDomacile erpDomacile,ERPAdmissionQuota erpAdmissionQuota,AcademicYear academicYear,def user, def ip)

    {
        println("dal :"+dal)
        if(dal==null) {
            dal = new DTEAllotmentList()
            dal.merit_no = Integer.parseInt(merit_no)
            dal.mht_cet_score = mht_cet_score
            dal.applicationid = application_id
            dal.name_of_candidate = name_of_candidate
            dal.jee_marks = jee_marks
            dal.diploma_marks = diploma_marks
            dal.erpround = erpAdmissionRound
            dal.category = erpStudentAdmissionMainCategory
            dal.gender = gender
            dal.erpseattype = erpSeatType
            dal.erpshift = erpShift
            dal.program = program
            dal.year = year
            dal.erpdomacile = erpDomacile
            dal.erpadmissionquota = erpAdmissionQuota
            dal.academicyear = academicYear
            dal.organization = org
            dal.save(flush: true, failOnError: true)

            ProvisionalAdmission provisionalAdmission = ProvisionalAdmission.findByApplicationNumberAndAcademicyear(application_id, academicYear)
            if(provisionalAdmission == null) {
                provisionalAdmission = new ProvisionalAdmission()
                provisionalAdmission.merit_no = Integer.parseInt(merit_no)
                provisionalAdmission.mht_cet_score = mht_cet_score
                provisionalAdmission.applicationNumber = application_id
                provisionalAdmission.fullname_as_per_previous_marksheet = name_of_candidate
                provisionalAdmission.erpround = erpAdmissionRound
                provisionalAdmission.category = erpStudentAdmissionMainCategory
                provisionalAdmission.gender = gender
                provisionalAdmission.erpseattype = erpSeatType
                provisionalAdmission.erpshift = erpShift
                provisionalAdmission.program = program
                provisionalAdmission.year = year
                provisionalAdmission.academicyear = academicYear
                provisionalAdmission.jee_marks = jee_marks
                provisionalAdmission.diploma_percentage = Double.parseDouble(diploma_marks)
                provisionalAdmission.erpadmissionquota = erpAdmissionQuota
                provisionalAdmission.organization = org
                provisionalAdmission.creation_username = user
                provisionalAdmission.creation_date = new java.util.Date()
                provisionalAdmission.creation_ip_address = ip
                provisionalAdmission.updation_username = user
                provisionalAdmission.updation_date = new java.util.Date()
                provisionalAdmission.updation_ip_address = ip
                provisionalAdmission.save(flush: true, failOnError: true)
            }
            return 1
        }
        else {
//            dal.merit_no = Integer.parseInt(merit_no)
//            dal.mht_cet_score = mht_cet_score
//            dal.applicationid = application_id
//            dal.name_of_candidate = name_of_candidate
//            dal.jee_marks = jee_marks
//            dal.diploma_marks = diploma_marks
//            dal.erpround = erpAdmissionRound
//            dal.category = erpStudentAdmissionMainCategory
//            dal.gender = gender
//            dal.erpseattype = erpSeatType
//            dal.erpshift = erpShift
//            dal.program = program
//            dal.year = year
//            dal.erpdomacile = erpDomacile
//            dal.erpadmissionquota = erpAdmissionQuota
//            dal.academicyear = academicYear
//            dal.organization = org
//            dal.save(flush: true, failOnError: true)
//            return 1
             return 0
        }
    }

    def sendAttendanceEmail(def learnerdivision, def attendanace, def user, def ip,request)
    {
        println("In sendAttendanceEmail")
        def learner = learnerdivision?.learner
        def dept = learnerdivision?.program?.department
        def org = learner?.organization
        SimpleDateFormat df = new SimpleDateFormat("dd-MM-yyyy")
        def date = df.format(attendanace?.execution_date);
        def erpcourseofferingbatchinstructor = attendanace?.erpcourseofferingbatchinstructor
        def attendanceslot = ERPCourseInstructorAttendanceSlot.findByErpcourseofferingbatchinstructorAndPeriod_numberAndErpcourseofferingbatch(erpcourseofferingbatchinstructor,attendanace?.period_number,erpcourseofferingbatchinstructor?.erpcourseofferingbatch)
        def emailsetting = ERPRoleTypeSettings.findByNameIlikeAndOrganization('Send Email to student if they are marked absent in attendance?', org)?.value
        if(emailsetting == 'true') {
            def msg = "Dear Parent ," +
                      "<br> Your ward " + learner?.person?.firstName + " " + learner?.person?.lastName + "  is/was absent for lecture no. " +attendanceslot?.slot?.slot_number + " (" + attendanceslot?.slot?.start_time + " - " + attendanceslot?.slot?.end_time + ") " + " (Subject: " + attendanace?.erpcourseoffering?.erpcourse?.course_code +" : " + attendanace?.erpcourseoffering?.erpcourse?.course_name + ") on "+ date + " in the college. Kindly Convey the reason." +
                      "<br> " + dept?.name + " Dept."
                      "<br> " + org?.organization_name
            ERPRelationType father = ERPRelationType.findByName( "Father" )
            ERPRelationType mother = ERPRelationType.findByName( "Mother" )
            ERPRelativeDetails erprelativedetailsfather = ERPRelativeDetails.findByErprelationtypeAndLearner( father, learner )
            ERPRelativeDetails erprelativedetailsmother = ERPRelativeDetails.findByErprelationtypeAndLearner( mother, learner )

            def email
            if (erprelativedetailsfather)
                email = erprelativedetailsfather?.email
            if (!email)
                email = erprelativedetailsmother?.email
//            email = 'komal@edupluscampus.com'
            println("email :"+email)
            if (org?.establishment_email && org?.establishment_email_credentials && email) {
                if(!attendanace?.emailsendonabsent) {
                    sendMailService.sendmailwithcss(request,org?.establishment_email, org.establishment_email_credentials, email, org?.organization_code + " Student Attendance", msg, "", "")
                    attendanace.emailsendonabsent = true
                    attendanace.username = user
                    attendanace.updation_date = new java.util.Date()
                    attendanace.updation_ip_address = ip
                    attendanace.save( flush: true, failOnError: true )
                }
            }
        }
    }

    def sendAttendanceSMS(def learnerdivision, def attendanace, def user, def ip){
        println("In sendAttendanceSMS")
        def learner = learnerdivision?.learner
        def dept = learnerdivision?.program?.department
        def org = learner?.organization
        SimpleDateFormat df = new SimpleDateFormat("dd-MM-yyyy")
        def date = df.format(attendanace?.execution_date);
        def erpcourseofferingbatchinstructor = attendanace?.erpcourseofferingbatchinstructor
        def attendanceslot = ERPCourseInstructorAttendanceSlot.findByErpcourseofferingbatchinstructorAndPeriod_numberAndErpcourseofferingbatch(erpcourseofferingbatchinstructor,attendanace?.period_number,erpcourseofferingbatchinstructor?.erpcourseofferingbatch)
        def smssetting = ERPRoleTypeSettings.findByNameIlikeAndOrganization('Send SMS to student if they are marked absent in attendance?', org)?.value
        if(smssetting == 'true') {
            SMSTemplateMaster smsTemplateMaster = SMSTemplateMaster.findBySmstypeAndOrganization("Attendance",org)
            //println("SMSTemplateMaster -->>"+ smsTemplateMaster)
            def msg = smsTemplateMaster?.text
            if (msg?.contains("\$@PRN"))
                msg = msg.replace("\$@PRN", learner?.person?.firstName + " " + learner?.person?.lastName)
            if (msg?.contains("\$@lectureNo"))
                msg = msg.replace("\$@lectureNo", " Subject: " + attendanace?.erpcourseoffering?.erpcourse?.course_code )
            if (msg?.contains("\$@date"))
                msg = msg.replace("\$@date", date)
            if (msg?.contains("\$@slotNumber"))
                msg = msg.replace("\$@slotNumber", attendanceslot?.slot?.start_time + " - " + attendanceslot?.slot?.end_time)

//            def msg = "Dear Parent ," +
//                    "<br> Your ward " + learner?.person?.firstName + " " + learner?.person?.lastName + "  is/was absent for lecture no. " +attendanceslot?.slot?.slot_number + " (" + attendanceslot?.slot?.start_time + " - " + attendanceslot?.slot?.end_time + ") " + " (Subject: " + attendanace?.erpcourseoffering?.erpcourse?.course_code +" : " + attendanace?.erpcourseoffering?.erpcourse?.course_name + ") on "+ date + " in the college. Kindly Convey the reason." +
//                    "<br> " + dept?.name + " Dept." +
//                    "<br> " + org?.organization_name

            ERPRelationType father = ERPRelationType.findByName( "Father" )
            ERPRelationType mother = ERPRelationType.findByName( "Mother" )
            ERPRelativeDetails erprelativedetailsfather = ERPRelativeDetails.findByErprelationtypeAndLearner( father, learner )
            ERPRelativeDetails erprelativedetailsmother = ERPRelativeDetails.findByErprelationtypeAndLearner( mother, learner )

            def mobile_no
            if (erprelativedetailsfather)
                mobile_no = erprelativedetailsfather?.mobile_no
            if (!mobile_no)
                mobile_no = erprelativedetailsmother?.mobile_no

//            mobile_no = '9922834870'
            if (mobile_no) {
                if(!attendanace?.smssendonabsent) {
                    InformationService.smsCommonService( msg, mobile_no, org, null)
                    attendanace.smssendonabsent = true
                    attendanace.username = user
                    attendanace.updation_date = new java.util.Date()
                    attendanace.updation_ip_address = ip
                    attendanace.save(flush: true, failOnError: true)
                }
            }
        }
    }

    def SendWhatsAppSMS(def learnerdivision, def attendanace, def user, def ip)
    {
        println("In Send WhatsApp SMS")

        def learner = learnerdivision?.learner
        def dept = learnerdivision?.program?.department?.name
        def org = learner?.organization

        def attendance_slot = ERPCourseInstructorAttendanceSlot.findByErpcourseofferingbatchinstructorAndPeriod_numberAndErpcourseofferingbatch(attendanace?.erpcourseofferingbatchinstructor,attendanace?.period_number,attendanace?.erpcourseofferingbatchinstructor?.erpcourseofferingbatch)
        SimpleDateFormat df = new SimpleDateFormat("dd-MM-yyyy")
        def date = df.format(attendanace?.execution_date)

        if(!org?.communication_access_key ||org?.communication_access_key==null) {
            return
        }

        def whatsapp_role_type_setting = ERPRoleTypeSettings.findByNameIlikeAndOrganization('Send Whatapp SMS to student if they are marked absent in attendance?', org)?.value
        println "whatsapp_role_type_setting -->>"+ whatsapp_role_type_setting

        if(whatsapp_role_type_setting == 'true') {

            ERPRelationType father = ERPRelationType.findByName("Father")
            ERPRelationType mother = ERPRelationType.findByName("Mother")
            ERPRelativeDetails relativeDetailsFather = ERPRelativeDetails.findByErprelationtypeAndLearner(father,learner)
            ERPRelativeDetails relativeDetailsMother = ERPRelativeDetails.findByErprelationtypeAndLearner(mother,learner)

            String mobile
            if (relativeDetailsFather)
                mobile = relativeDetailsFather?.mobile_no
            if (!mobile)
                mobile = relativeDetailsMother?.mobile_no

            println("mobile -->>"+mobile)

            String name = learner?.person?.firstName ? learner?.person?.firstName+" ":""
            String firstName = learner?.person?.firstName ? learner?.person?.firstName+" ":""
            name+=learner?.person?.lastName ? learner?.person?.lastName+" ":""
            name+=org?.organization_code ? org?.organization_code:""
            String lastName = learner?.person?.lastName ? learner?.person?.lastName+" ":""

            if (mobile != null && mobile!="" && mobile.length() >= 10) {
                int test = mobile.length() - 10
                mobile = mobile.substring(test);
                mobile = 91 + mobile
                HashMap hm = new HashMap()
                WhatsappAndZerobounceService whatsappService = new WhatsappAndZerobounceService()
                whatsappService.addWhatsappContact(org?.communication_access_key, mobile, name, "Parent", hm)
                if (hm.get("contactStatus") == "VALID") {
                    WhatAppTemplateCategory whatAppTemplateCategory = WhatAppTemplateCategory.findByNameAndOrganization("student_absent_msg", org)
                    if (whatAppTemplateCategory) {
                        WhatsAppTemplateCategoryMapping whatsAppTemplateCategoryMapping = WhatsAppTemplateCategoryMapping.findByWhatapptemplatecategoryAndOrganizationAndIsactive(whatAppTemplateCategory, org, true)
                        if (whatsAppTemplateCategoryMapping) {
                            def whatsAppTemplateParameter = WhatsAppTemplateParameter.findAllByWhatsapptemplateAndOrganization(whatsAppTemplateCategoryMapping?.whatsapptemplate, org)
                            ArrayList arrayList = new ArrayList()
                            for (eachWhatsAppTemplateParameter in whatsAppTemplateParameter) {
                                HashMap params = new HashMap()
                                params.put("name", eachWhatsAppTemplateParameter?.name)
                                if (eachWhatsAppTemplateParameter?.name == "first_name")
                                    params.put("value", firstName)
                                if (eachWhatsAppTemplateParameter?.name == "last_name")
                                    params.put("value", lastName)
                                if (eachWhatsAppTemplateParameter?.name == "period_number")
                                    params.put("value", attendance_slot?.slot?.start_time+"-"+attendance_slot?.slot?.end_time)
                                if (eachWhatsAppTemplateParameter?.name == "course_name")
                                    params.put("value", attendanace?.erpcourseoffering?.erpcourse?.course_name)
                                if (eachWhatsAppTemplateParameter?.name == "date")
                                    params.put("value", date)
                                if (eachWhatsAppTemplateParameter?.name == "department_name")
                                    params.put("value", dept)
                                if (eachWhatsAppTemplateParameter?.name == "organization_name")
                                    params.put("value", org?.organization_code)
                                arrayList.add(params)
                            }
                            def service = whatsappService.whatsappsendmessagetemplate(org?.communication_access_key, mobile, whatsAppTemplateCategoryMapping?.whatsapptemplate?.name, "Student Absent Msg", arrayList)
                            if(service==-1) {
                                println("Error In API")
                            }
                            else if(service==true) {
                                println("On Success")
                                attendanace.whatsappsendonabsent = true
                                attendanace.username = user
                                attendanace.updation_date = new java.util.Date()
                                attendanace.updation_ip_address = ip
                                attendanace.save(flush: true, failOnError: true)
                            }
                        }
                    }
                }
            }
        }
    }

    def getRecDepartment(Organization org, RecVersion recver){
        def recdept = RecBranch.findAllByOrganizationAndRecversionAndIsactive(org, recver, true)?.program?.department
        HashSet departmentlist = []
        departmentlist.addAll(recdept)
        departmentlist.sort{it.name}

        return  departmentlist
    }

    def getRecProgram(Organization org, RecVersion recver){
        def recprog = RecBranch.findAllByOrganizationAndRecversionAndIsactive(org, recver, true)?.program
        HashSet programlist = []
        programlist.addAll(recprog)
        programlist.sort{it.name}

        return  programlist
    }


    @org.springframework.transaction.annotation.Transactional
    def learnerNotificationHistory(def to, def learner, def ntext, def user, def ip, def studentreadreceipt, def successstatus, def msg, def reasonoffailure){
        println("in learnerNotificationHistory  ")
        def body = notificationtext(learner, ntext?.body)
        if(body?.contains("\$@TEMP1") || body?.contains("\$@TEMP2") || body?.contains("\$@TEMP3") || body?.contains("\$@TEMP4") || body?.contains("\$@TEMP5")) {
            successstatus = false
            reasonoffailure = "TEMP Variable value not present for this student."
        }

        ERPLearnerNotificationHistory lnh = new ERPLearnerNotificationHistory()
        lnh.noticationto = to
        lnh.organization = learner?.organization
        lnh.learner = learner
        lnh.erpnotificationtext = ntext
        lnh.notificationtext = msg
        lnh.studentreadreceipt = studentreadreceipt
        lnh.successstatus = successstatus
        lnh.reasonoffailure = reasonoffailure

        lnh.username = user
        lnh.creation_date = new java.util.Date()
        lnh.updation_date = new java.util.Date()
        lnh.creation_ip_address = ip
        lnh.updation_ip_address = ip
        lnh.save(flush: true, failOnError: true)

//        println("lnh "+lnh)
        return lnh
    }

    def systemNotificationHistory(def subject, def body, def from, def instructor, def commode, def ntt, def file_name_history, def file_path_history, def user, def ip, def smstemplate){

        println "SYSTEM NOTIFICATION HISTORY"
        ERPNotificationText ntext = new ERPNotificationText()
        ntext.subject = subject
        ntext.body = body
        ntext.file_name = file_name_history
        ntext.file_path = file_path_history
        ntext.notificationfrom = from
        ntext.sentdate = new java.util.Date()
        ntext.organization = instructor?.organization
        ntext.sentby = instructor
        ntext.erpcommunicationmode = commode
        ntext.erpnotificationtotype = ntt

        ntext.smstemplatemaster = smstemplate
        ntext.username=user
        ntext.creation_date=new java.util.Date()
        ntext.updation_date=new java.util.Date()
        ntext.creation_ip_address=ip
        ntext.updation_ip_address=ip
        ntext.save(flush: true,failOnError: true)

        return ntext
    }

    @Transactional
    def notificationtext(def learner, def msg){

        ApplicationType atacad =ApplicationType.findByApplication_type("ERP")
        RoleType rtacad = RoleType.findByApplicationtypeAndTypeAndOrganization(atacad, 'Academics', learner?.organization)
        ApplicationAcademicYear aay = ApplicationAcademicYear.findByRoletypeAndIsActiveAndOrganization(rtacad, true, learner?.organization)
        def learnerdivision = LearnerDivision.findByLearnerAndAcademicyearAndSemesterAndIsdeleted(learner, aay?.academicyear, aay?.semester, false)

        def replacements = [
                '\$@PRN': learner?.registration_number,
                '\$@PROG': learner?.program?.name,
                '\$@EMAIL': learner?.uid,
                '\$@DEPT': learner?.program?.department?.name,
                '\$@FULLNAME': learner?.person?.fullname_as_per_previous_marksheet,
                '\$@FIRSTNAME': learner?.person?.firstName,
                '\$@LASTNAME': learner?.person?.lastName,
                '\$@TEMP1': learner?.temp1,
                '\$@TEMP2': learner?.temp2,
                '\$@TEMP3': learner?.temp3,
                '\$@TEMP4': learner?.temp4,
                '\$@TEMP5': learner?.temp5,
                '\$@YEAR': learnerdivision?.year?.display_name,
                '\$@DIV': learnerdivision?.divisionoffering?.division?.name,
                '\$@ROLL': "${learnerdivision?.rollnumbersuffix ?: ''}${learnerdivision?.rollno ?: ''}"
        ]

        replacements.each { key, value ->
            if (msg?.contains(key)) {
                msg = msg.replaceAll("\\${key}", value ?: "")
            }
        }

//        println "MSG "+msg

//        if(msg?.contains("\$@PRN"))
//            msg = msg.replace("\$@PRN", learner?.registration_number)
//
//        if(msg?.contains("\$@PROG"))
//            msg = msg.replace("\$@PROG", learner?.program?.name ? learner?.program?.name : "")
//        if(msg?.contains("\$@EMAIL"))
//            msg = msg.replace("\$@EMAIL", learner?.uid)
