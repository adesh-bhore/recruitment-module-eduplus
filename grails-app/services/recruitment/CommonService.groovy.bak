    def notificationEmployetext(def instructor, def msg){
        if(msg?.contains("\$@PRN"))
            msg = msg.replace("\$@PRN", instructor?.employee_code)
        if(msg?.contains("\$@EMAIL"))
            msg = msg.replace("\$@EMAIL", instructor?.uid)
        if(msg?.contains("\$@PROG"))
            msg = msg.replace("\$@PROG", instructor?.program?.name ? instructor?.program?.name : "")

        if(msg?.contains("\$@DEPT"))
            msg = msg.replace("\$@DEPT", instructor?.department?.name ? instructor?.department?.name : "")

        if(msg?.contains("\$@FULLNAME"))
            msg = msg.replace("\$@FULLNAME", instructor?.person?.fullname_as_per_previous_marksheet ? instructor?.person?.fullname_as_per_previous_marksheet : "")

        if(msg?.contains("\$@FIRSTNAME"))
            msg = msg.replace("\$@FIRSTNAME", instructor?.person?.firstName ? instructor?.person?.firstName : "")

        if(msg?.contains("\$@LASTNAME"))
            msg = msg.replace("\$@LASTNAME", instructor?.person?.lastName ? instructor?.person?.lastName : "")
        return msg
    }



    def fetchLearnerDetails(arrayList,learner,params,hm)
    {
        println("In fetchLearnerDetails ==>"+ params)

        if (learner) {
            def erpDocumentType=ERPDocumentType.findAllByOrganization(learner.organization)
            for(eacherpDocumentType in erpDocumentType) {
                ERPDocuments erpDocuments = ERPDocuments.findByLearnerAndOrganizationAndErpdocumenttype(learner, learner.organization,eacherpDocumentType)
                if (erpDocuments) {
                    HashMap temp = new HashMap()
                    temp.put("id", erpDocuments?.learner?.id)
                    temp.put("prn", erpDocuments?.learner?.registration_number)
                    temp.put("name", erpDocuments?.learner?.person?.fullname_as_per_previous_marksheet)
                    temp.put("program", erpDocuments?.learner?.program?.name)
                    temp.put("grno", erpDocuments?.learner?.person?.grno)
                    temp.put("docerpname", erpDocuments?.erpdocumenttype?.document_name)
                    temp.put("doctypeid", erpDocuments?.erpdocumenttype?.id)
                    temp.put("documentpath", erpDocuments?.documentpath ? erpDocuments?.documentpath :"NA")
                    temp.put("docname", erpDocuments?.documentname ? erpDocuments?.documentname :"NA")
                    temp.put("erpdocid", erpDocuments?.id)
                    temp.put("category", erpDocuments?.learner?.admittederpstudentadmissionmaincategory?.category)
                    arrayList.add(temp)
                }else{
                    HashMap temp = new HashMap()
                    temp.put("id", learner?.id)
                    temp.put("prn", learner?.registration_number)
                    temp.put("name", learner?.person?.fullname_as_per_previous_marksheet)
                    temp.put("program", learner?.program?.name)
                    temp.put("grno", learner?.person?.grno)
                    temp.put("docerpname", eacherpDocumentType?.document_name)
                    temp.put("doctypeid", eacherpDocumentType?.id)
                    temp.put("documentpath","NA")
                    temp.put("docname", "NA")
                    temp.put("erpdocid", erpDocuments?.id)
                    temp.put("category",learner?.admittederpstudentadmissionmaincategory?.category)
                    arrayList.add(temp)
                }
            }
        }
        hm.put("learnerDetails", arrayList)
        hm.put("msg", "200")
        hm.put("status", "success")

        return
    }


    def aesEncrypt(data,key)
    {
        AesCryptUtil aesUtil=new AesCryptUtil(key);
        String encRequest = aesUtil.encrypt(data.toString());
        return encRequest
    }

    def aesDecrypt(data,key)
    {
        String decResp=""
        try {
            AesCryptUtil aesUtil = new AesCryptUtil(key);
            decResp = aesUtil.decrypt(data.toString());
            return decResp
        }
        catch (Exception e)
        {
            return  decResp
        }
        finally {
            return  decResp
        }
    }

