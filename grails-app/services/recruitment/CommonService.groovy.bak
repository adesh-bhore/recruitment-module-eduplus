    def getAutoGeneratedEmployeeCode(def organizationDetails)
    {
                def employee_code_counter= organizationDetails?.employee_code_counter
                def terminate_loop=0
                def flag=false
                while (true){
                    terminate_loop++
                    if(terminate_loop>=200)
                        break
                    Instructor checkifexists = Instructor.findByEmployee_code(employee_code_counter)
                    Person checkperson = Person.findByGrno(employee_code_counter)
                    if(!checkifexists && !checkperson){
                        flag=true
                        break
                    }
                    employee_code_counter++
                }
                if(flag){
                    organizationDetails.employee_code_counter=employee_code_counter
                    organizationDetails.save(flush: true,failOnError: true)
                    return employee_code_counter
                }
    }
