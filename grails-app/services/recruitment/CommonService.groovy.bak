        def designation = Designation.findByOrganization(instructor.organization)
        RecPost rec = RecPost.findById(params?.recPostId)
        RecPostDocument recPostDocument1 = RecPostDocument.findByRecDocumentTypeAndRecPost(recDocumentType,rec)
        if (recPostDocument1) {
            flash.message = "RecPostDocument already exists."
            return
        }
        def recPostDocument = new RecPostDocument()
        recPostDocument.isCompulsory = false
        recPostDocument.recPost = rec
        recPostDocument.recDocumentType = recDocumentType
        recPostDocument.creation_username = login.username
        recPostDocument.updation_username = login.username
        recPostDocument.creation_date = new Date()
        recPostDocument.updation_date = new Date()
        recPostDocument.creation_ip_address = request.getRemoteAddr()
        recPostDocument.updation_ip_address = request.getRemoteAddr()
        recPostDocument.updation_ip_address = request.getRemoteAddr()
        recPostDocument.save(failOnError: true, flush: true)
        flash.message = "Saved Successfully"
    }

    def editRecPostDocument(params, session, request, flash) {
        println("editRecPostDocument --------" + params)
        Login login = Login.findById(session.loginid)
        Instructor instructor = Instructor.findByUid(login.username)
        def recPostId = params?.recPostId?.toLong()
        RecDocumentType recDocumentType = RecDocumentType.findById(params?.recDocumentType)
        def recPost = RecPost.findById(recPostId)
        RecPostDocument recPostDocument1 = RecPostDocument.findByRecDocumentTypeAndRecPost(recDocumentType,recPost)
        if (recPostDocument1 && recPostDocument1.id != params.id.toLong()) {
            flash.message = "RecPostDocument already exists."
            return
        }
        RecPostDocument recPostDocument = RecPostDocument.findById(params.id)
        if (!recPostDocument) {
            flash.message = "RecPostDocument not found."
            return
        }
        recPostDocument.id = params.id.toLong()
//        recPostDocument.isCompulsory = false
        recPostDocument.recDocumentType = recDocumentType
        recPostDocument.recPost = recPost
        recPostDocument.updation_username = login.username
        recPostDocument.updation_date = new Date()
        recPostDocument.updation_ip_address = request.getRemoteAddr()

        recPostDocument.save(failOnError: true, flush: true)
        flash.message = "Edit Successfully"
    }

    def compulsoryRecPostDocument(params, session, request, flash) {
        println("compulsoryRecPostDocument --------" + params)
        Login login = Login.findById(session.loginid)
        Instructor instructor = Instructor.findByUid(login.username)
        RecPostDocument recPostDocument = RecPostDocument.findById(params.isCompulsoryId) // Ensure correct ID parameter

        if (recPostDocument) {
            recPostDocument.isCompulsory = !recPostDocument.isCompulsory
            recPostDocument.updation_ip_address = request.getRemoteAddr()
            recPostDocument.updation_date = new java.util.Date()
            recPostDocument.save(flush: true, failOnError: true)

            flash.message = recPostDocument.isCompulsory ? "Activated Successfully" : "Deactivated Successfully"
        }

    }

    def deleteRecPostDocument(params, session, request,flash) {
        println("deleteRecPostDocument --------" + params)
        Login login = Login.findById(session.loginid)
        Instructor instructor = Instructor.findByUid(login.username)
        RecPostDocument recPostDocument = RecPostDocument.findById(params?.deleteId)
        recPostDocument.delete(failOnError: true, flush: true)
        flash.message = "Deleted Successfully"
    }
}
