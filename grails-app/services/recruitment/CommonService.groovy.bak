    def addNEPCourseCategory(params, session, request, flash) {
        println("addNEPCourseCategory --------" + params)

        Login login = Login.findById(session.loginid)
        Instructor instructor = Instructor.findByUid(login.username)

        def organizationlist = Organization.findAll()
        def nEPCourseCategoryList = NEPCourseCategory.findAllByOrganization(instructor?.organization)
        def courseRuleList = CourseRule.findAllByOrganization(instructor?.organization)

        [nEPCourseCategoryList: nEPCourseCategoryList,organizationlist:organizationlist,courseRuleList:courseRuleList]
    }

    def saveNEPCourseCategory(params, session, request, flash) {
        println("saveNEPCourseCategory --------" + params)

        Login login = Login.findById(session.loginid)
        Instructor instructor = Instructor.findByUid(login.username)
        def organization = instructor.organization
        def courseRule = CourseRule.findById(params?.courseRule)
        NEPCourseCategory existingCategory = NEPCourseCategory.findByNameAndOrganizationAndDisplay_nameAndCourserule(params?.name, organization,params?.display_name,courseRule)
        if (existingCategory) {
            flash.error = "NEPCourseCategory '${params?.name}' '${params?.display_name}' & '${courseRule.name}'  already exists for the organization."
            return
        }

        def nEPCourseCategory = new NEPCourseCategory()
        nEPCourseCategory.name = params?.name
        nEPCourseCategory.display_name = params?.display_name
        nEPCourseCategory.courserule = courseRule
        nEPCourseCategory.isactive = params?.isactive?.toBoolean() ?: true
        nEPCourseCategory.organization = organization
        nEPCourseCategory.username = login.username
        nEPCourseCategory.creation_date = new Date()
        nEPCourseCategory.creation_ip_address = request.getRemoteAddr()
        nEPCourseCategory.updation_date = new Date()
        nEPCourseCategory.updation_ip_address = request.getRemoteAddr()
        nEPCourseCategory.save(failOnError: true, flush: true)
        flash.message = "Saved Successfully..."
    }

    def editNEPCourseCategory(params, session, request, flash) {
        println("editNEPCourseCategory --------" + params)

        Login login = Login.findById(session.loginid)
        Instructor instructor = Instructor.findByUid(login.username)
        def organization = instructor.organization
        def courseRule = CourseRule.findById(params?.courseRule)
        NEPCourseCategory existingCategory = NEPCourseCategory.findByNameAndOrganizationAndDisplay_nameAndCourserule(params?.name, organization,params?.display_name,courseRule)
        if (existingCategory && existingCategory.id != params.id.toLong()) {
            flash.error = "NEPCourseCategory '${params?.name}' '${params?.display_name}' & '${courseRule.name}' already exists for the organization."
            return
        }

        NEPCourseCategory nEPCourseCategory = NEPCourseCategory.findById(params.id)
        if (!nEPCourseCategory) {
            flash.error = "NEPCourseCategory not found."
            return
        }

        nEPCourseCategory.name = params?.name
        nEPCourseCategory.display_name = params?.display_name
        nEPCourseCategory.courserule = courseRule
        nEPCourseCategory.isactive = params?.isactive?.toBoolean() ?: nEPCourseCategory.isactive
        nEPCourseCategory.organization = nEPCourseCategory.organization
        nEPCourseCategory.updation_date = new Date()
        nEPCourseCategory.updation_ip_address = request.getRemoteAddr()
        nEPCourseCategory.save(failOnError: true, flush: true)
        flash.message = "Edit Successfully..."
    }

    def activeNEPCourseCategory(params, session, request,flash){
        println("activeNEPCourseCategory --------"+params)
        Login login = Login.findById(session.loginid)
        Instructor instructor = Instructor.findByUid(login.username)
        NEPCourseCategory nEPCourseCategory = NEPCourseCategory.findById(params?.isactiveId)

        if (nEPCourseCategory) {
            if (nEPCourseCategory.isactive) {
                nEPCourseCategory.isactive = false
                flash.message = "Deactivated Successfully..."
            } else {
                nEPCourseCategory.isactive = true
                flash.message = "Activated Successfully..."
            }
            nEPCourseCategory.updation_ip_address = request.getRemoteAddr()
            nEPCourseCategory.updation_date = new java.util.Date()
            nEPCourseCategory.save(flush: true, failOnError: true)
        }
    }

    def deleteNEPCourseCategory(params, session, request,flash){
        println("deleteNEPCourseCategory --------"+params)
        Login login = Login.findById(session.loginid)
        Instructor instructor = Instructor.findByUid(login.username)

        NEPCourseCategory nEPCourseCategory = NEPCourseCategory.findById(params?.deleteId)

        if (nEPCourseCategory) {
            try {
                nEPCourseCategory.delete(flush: true, failOnError: true)
                flash.message = "Deleted successfully..."
            } catch (Exception e) {
                flash.error = " Cannot be Deleted .."
            }
        } else {
            flash.error = "  Not found"
        }

    }

    def getAge(date) {
        try{
            if (!date) return 0  // Return 0 if no date is provided
            Date birthDate

            if (date instanceof String) {
                // If date is a String, parse it
                SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd")
                birthDate = sdf.parse(date)
            } else if (date instanceof Timestamp || date instanceof Date) {
                // If date is a Timestamp or Date, convert directly
                birthDate = new Date(date.time)
            } else {
                throw new IllegalArgumentException("Unsupported date format")
            }

            Calendar current = Calendar.getInstance()
            Calendar birth = Calendar.getInstance()
            birth.time = birthDate
            int age = current.get(Calendar.YEAR) - birth.get(Calendar.YEAR)
            if (current.get(Calendar.DAY_OF_YEAR) < birth.get(Calendar.DAY_OF_YEAR)) {
                age--
            }

            return age
        }catch(Exception e){
            println("Error calculating age :"+e)
            return 0
        }
    }

    def getAttendancePercentage(params, learnerdivision, crsbatch){
        println("In getAttendancePercentage")
        double percentage = 0
        if (learnerdivision) {
            def learner =  learnerdivision?.learner
            def organization =  learner?.organization
            ERPExamConductType erpExamConductType = ERPExamConductType.findByTypeAndOrganization("Regular", organization)
            AcademicYear academicyear = AcademicYear.findById(params.ay)
            Semester semester = Semester.findById(params.sem)
            def courseoffering = ERPCourseOfferingLearner.findAllByAcademicyearAndSemesterAndLearnerAndOrganizationAndErpexamconducttypeAndIscancelled(academicyear, semester, learnerdivision?.learner, organization, erpExamConductType, false)
            def totallectureattended = 0
            def actuallecturecount = 0
            for (course in courseoffering) {
                def courseofferinglist = ERPCourseOffering.findAllByAcademicyearAndSemesterAndErpcourseAndOrganizationAndCoursetype(course?.erpcourseoffering?.academicyear, course?.erpcourseoffering?.semester, course?.erpcourseoffering?.erpcourse, organization, course?.erpcourseoffering?.coursetype)
                if (courseofferinglist) {
                    def erpcourseofferingbatchlearner = ERPCourseOfferingBatchLearner.createCriteria().list() {
                        'in'('learner', learner)
                        and {
//                            'in'('erpcourseoffering', courseofferinglist)
                            'in'('erpcourseofferingbatch', crsbatch)
                        }
                    }
                    for (batch in erpcourseofferingbatchlearner) {
                        def studentbatch
                        if (batch?.erpcourseoffering?.courserule?.name == 'EL' && batch?.erpcourseoffering?.erpcoursecategory?.name != 'EL-Div') {
                            if (batch?.erpcourseofferingbatch?.divisionoffering == null) {
                                studentbatch = batch
                            }

                        } else {
                            if (batch?.erpcourseofferingbatch?.divisionoffering != null) {
                                studentbatch = batch
                            }
                        }
                        if (studentbatch) {
                            def lecturetotal = ERPCourseOfferingBatchLearnerAttendance.createCriteria().list() {
                                projections {
                                    distinct('period_number')
                                }
                                and {
//                                    'in'('erpcourseoffering', courseofferinglist)
                                    'in'('erpcourseofferingbatchlearner', studentbatch)
                                }
                            }?.size()

                            def lectureattended = ERPCourseOfferingBatchLearnerAttendance.createCriteria().list() {
                                projections {
                                    distinct('period_number')
                                }
                                and {
//                                    'in'('erpcourseoffering', courseofferinglist)
                                    'in'('erpcourseofferingbatchlearner', studentbatch)
                                    eq('is_present', true)
                                }
                            }?.size()

                            actuallecturecount = actuallecturecount + lecturetotal
                            totallectureattended = totallectureattended + lectureattended
                        }
                    }
                }
            }
            if(actuallecturecount && totallectureattended){
                percentage = (totallectureattended / actuallecturecount) * 100
                percentage = (percentage)?.round(2)
            }
        }
        println("percentage = "+percentage)

        return percentage
    }

    def getStudentAttendanceData(learnerdivision, fromdate, todate){
        if (learnerdivision) {
            def learner =  learnerdivision?.learner
            def organization =  learner?.organization
            SimpleDateFormat inputFormat = new SimpleDateFormat("yyyy-MM-dd")
            def startdate = inputFormat.parse(fromdate)
            def enddate = inputFormat.parse(todate)
            startdate.setHours(00);
            startdate.setMinutes(00);
            startdate.setSeconds(00);
            enddate.setHours(23);
            enddate.setMinutes(59);
            enddate.setSeconds(59);
            ERPExamConductType erpExamConductType = ERPExamConductType.findByTypeAndOrganization("Regular", organization)
            def courseoffering_learner = ERPCourseOfferingLearner.findAllByAcademicyearAndSemesterAndLearnerAndOrganizationAndErpexamconducttypeAndIscancelled(learnerdivision?.academicyear, learnerdivision?.semester, learnerdivision?.learner, organization, erpExamConductType, false)
            def totallectureattended = 0
            def actuallecturecount = 0
            def courseWiseAttendanceData = []
            if (courseoffering_learner) {
                def erpcourseofferingbatchlearner = ERPCourseOfferingBatchLearner.createCriteria().list() {
                    'in'('learner', learner)
                    and {
                        'in'('erpcourseoffering', courseoffering_learner?.erpcourseoffering)
                    }
                }
                for (batch in erpcourseofferingbatchlearner) {
                    def studentbatch
                    if (batch?.erpcourseoffering?.courserule?.name == 'EL' && batch?.erpcourseoffering?.erpcoursecategory?.name != 'EL-Div') {
                        if (batch?.erpcourseofferingbatch?.loadtype?.type?.type == 'Theory') {
                            if (batch?.erpcourseofferingbatch?.divisionoffering == null) {
                                studentbatch = batch
                            }
                        }
                    } else {
                        if (batch?.erpcourseofferingbatch?.loadtype?.type?.type == 'Theory') {
                            if (batch?.erpcourseofferingbatch?.divisionoffering != null) {
                                studentbatch = batch
                            }
                        }
                    }
                    if (studentbatch) {
                        def lecturetotal = ERPCourseOfferingBatchLearnerAttendance.createCriteria().list() {
                            projections {
                                distinct('period_number')
                            }
                            and {
                                'in'('erpcourseoffering', courseoffering_learner?.erpcourseoffering)
                                'in'('erpcourseofferingbatchlearner', studentbatch)
                                between("execution_date", startdate, enddate)
                            }
                        }?.size()
                        def lectureattended = ERPCourseOfferingBatchLearnerAttendance.createCriteria().list() {
                            projections {
                                distinct('period_number')
                            }
                            and {
                                'in'('erpcourseoffering', courseoffering_learner?.erpcourseoffering)
                                'in'('erpcourseofferingbatchlearner', studentbatch)
                                between("execution_date", startdate, enddate)
                                eq('is_present', true)
                            }
                        }?.size()
                        courseWiseAttendanceData.add(course_code : batch?.erpcourseoffering?.erpcourse?.course_name, attented_lecture : lectureattended, total_lecture :lecturetotal

                        )

                    }
                }
            }
            return courseWiseAttendanceData
        }
    }

