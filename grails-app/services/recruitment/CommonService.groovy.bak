    def getDate2(changeDate)
    {
        def today = changeDate
        def year = today.getYear() + 1900
        def day = today.getDate() > 9 ? today.getDate() : '0' + today.getDate()
        def month = (today.getMonth() + 1) > 9 ? (today.getMonth() + 1) : '0' + (today.getMonth() + 1)
        return year + '-' + month + '-' + day
    }

    def standarddeviation(data){
        int n = data?.size();

        // Calculate mean
        double sum = 0;
        for (num in data)
            sum += num;
        double mean = sum / n;

        double sumOfSquaredDifferences = 0;
        for (num in data)
            sumOfSquaredDifferences += Math.pow(num - mean, 2);
        double standardDeviation = Math.sqrt(sumOfSquaredDifferences / n);
        return standardDeviation?.round(2)
    }


    // Exam Notification
    def learnerNotificationOnExamFormApproval(def learner, def instructor, def msg, def user, def ip){
        println("learnerNotificationOnExamFormApproval  ")

        def ntt = ERPNotificationToType.findByTypeAndOrganizationAndIsactive('Student', learner?.organization, true)
        if (ntt) {
            def commode = ERPCommunicationMode.findByOrganizationAndMode(learner?.organization, 'System Notification')
            def ntext = ERPNotificationText.findBySubjectAndOrganizationAndErpcommunicationmodeAndSentby("Exam Form Approval Status", learner?.organization, commode, instructor)
            if(!ntext){
                ntext = new ERPNotificationText()
                ntext.subject = "Exam Form Approval Status"
                ntext.body = msg
                ntext.notificationfrom = "Examination"
                ntext.organization = learner?.organization
                ntext.sentby = instructor
                ntext.erpcommunicationmode = commode
                ntext.erpnotificationtotype = ntt
                ntext.sentdate = new java.util.Date()

                ntext.username=user
                ntext.creation_date=new java.util.Date()
                ntext.updation_date=new java.util.Date()
                ntext.creation_ip_address=ip
                ntext.updation_ip_address=ip
                ntext.save(flush: true,failOnError: true)
            }
            ERPLearnerNotificationHistory lnh = new ERPLearnerNotificationHistory()
            lnh.noticationto = learner?.registration_number
            lnh.organization = learner?.organization
            lnh.learner = learner
            lnh.notificationtext = msg
            lnh.studentreadreceipt = false
            lnh.erpnotificationtext = ntext
            lnh.successstatus = true
            lnh.reasonoffailure = ""

            lnh.username = user
            lnh.creation_date = new java.util.Date()
            lnh.updation_date = new java.util.Date()
            lnh.creation_ip_address = ip
            lnh.updation_ip_address = ip
            lnh.save(flush: true, failOnError: true)
        }
    }

