    def notificationLeadmanagertext(def leadmanager, def msg){
        if(msg?.contains("\$@PRN"))
            msg = msg.replace("\$@PRN", "")

        if(msg?.contains("\$@PROG"))
            msg = msg.replace("\$@PROG", "")

        if(msg?.contains("\$@DEPT"))
            msg = msg.replace("\$@DEPT",  "")

        if(msg?.contains("\$@FULLNAME"))
            msg = msg.replace("\$@FULLNAME", leadmanager?.fullName ? leadmanager?.fullName :   leadmanager?.firstName + "  "+ leadmanager?.lastName)

        if(msg?.contains("\$@FIRSTNAME"))
            msg = msg.replace("\$@FIRSTNAME", leadmanager?.firstName ? leadmanager?.firstName : "")

        if(msg?.contains("\$@LASTNAME"))
            msg = msg.replace("\$@LASTNAME", leadmanager?.lastName ? leadmanager?.lastName : "")
        return msg
    }

