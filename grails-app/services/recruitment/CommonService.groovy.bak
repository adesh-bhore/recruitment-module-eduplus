//        if(msg?.contains("\$@FULLNAME"))
//            msg = msg.replace("\$@FULLNAME", learner?.person?.fullname_as_per_previous_marksheet ? learner?.person?.fullname_as_per_previous_marksheet : "")
//
//        if(msg?.contains("\$@FIRSTNAME"))
//            msg = msg.replace("\$@FIRSTNAME", learner?.person?.firstName ? learner?.person?.firstName : "")
//
//        if(msg?.contains("\$@LASTNAME"))
//            msg = msg.replace("\$@LASTNAME", learner?.person?.lastName ? learner?.person?.lastName : "")
//
//        if(msg?.contains("\$@TEMP1")) {
//            if(learner?.temp1)
//                msg = msg.replace("\$@TEMP1", learner?.temp1)
//        }
//
//        if(msg?.contains("\$@TEMP2")) {
//            if(learner?.temp2)
